---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE } from '@/config';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

function postHref(slug: string): string {
  return `${import.meta.env.BASE_URL}posts/${slug}/`.replace(/\/+/g, '/');
}

function categoryHref(c: string): string {
  return `${import.meta.env.BASE_URL}categories/${encodeURIComponent(c)}/`.replace(/\/+/g, '/');
}

function fmt(d: Date): string {
  return `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
}
---

<BaseLayout>
  <section class="container">
    <div class="index-hero">
      <h1 class="index-hero__title">{SITE.title}</h1>
      <p class="index-hero__lead">{SITE.tagline} — hedge-rich、誠懇、留下被打臉的空間。不是 best practice、不是 tutorial、是觀察筆記。</p>
    </div>

    <h2 class="index-section-title">最新文章</h2>
    <ul class="post-list">
      {posts.map((post) => (
        <li class="post-card">
          <p class="post-card__meta">
            <time datetime={post.data.date.toISOString().slice(0, 10)}>{fmt(post.data.date)}</time>
            {post.data.categories.length > 0 && (
              <>
                {' · '}
                {post.data.categories.map((c, i) => (
                  <>
                    {i > 0 && ' / '}
                    <a class="chip" href={categoryHref(c)}>{c}</a>
                  </>
                ))}
              </>
            )}
          </p>
          <h3 class="post-card__title">
            <a href={postHref(post.slug)}>{post.data.title}</a>
          </h3>
          <p class="post-card__summary">{post.data.summary}</p>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
